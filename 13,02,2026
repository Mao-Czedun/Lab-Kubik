void removeElem(List* head, int value)
{
	if (head == nullptr)
	{
		cout << "" << endl;
		return;
	}
	if (head->data == value)
	{
		List* tmp = head; 
		head = head->next;
		delete tmp; return;
	}
	
	List* tmp = head;
	while (tmp->next != nullptr)
	{
		tmp = tmp->next;
	}
	if (tmp->next = nullptr)
	{
		cout << "" << endl; return;
	}
	List* delElem = tmp->next;
	tmp->next = tmp->next->next;
	delete delElem;
}

// Функция очистки списка
void clearlist(List*& head) {
	while (head != nullptr) {
		List* tmp = head;
		head = head->next;
		delete tmp;
	}
}

void zerolist(List*& head) {
	cout << "Список элеменов обнулен" << endl;
	List* tmp = head;
	while (tmp != nullptr) {
		tmp->data = 0;
		tmp = tmp->next;
	}
}

