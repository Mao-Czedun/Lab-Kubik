using namespace std;



struct List {
	int data;
	List* next;
};



List* createList(int value)
{
	List* newL = new List;
	newL->data = value;
	newL->next = NULL;
	return newL;
}


void PrintList(List* head){
	List* tmp = head;
	while (head != nullptr) //NULL
	{
		cout << tmp->data << " ";
		tmp = tmp->next;
	}
}



void appEnd(List*& head, int value)
{
	List* newL = createList(value); 
	if (head == nullptr)
	{
		head = newL;
	}
	else {
		List* tmp = head;
		while (tmp->next != nullptr)
		{
			tmp = tmp->next;
			
		}
	tmp->next = newL;
	}
}



