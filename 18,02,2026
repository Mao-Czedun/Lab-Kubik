using namespace std;



struct List {
	int data;
	List* next;
};



List* createList(int value)
{
	List* newL = new List;
	newL->data = value;
	newL->next = NULL;
	return newL;
}


void PrintList(List* head) {
	List* tmp = head;
	while (head != nullptr) //NULL
	{
		if ((tmp) == nullptr) {
			break;
		}
		cout << tmp->data << " ";
		tmp = tmp->next;
	}
}



void appEnd(List*& head, int value)
{
	List* newL = createList(value);
	if (head == nullptr)
	{
		head = newL;
	}
	else {
		List* tmp = head;
		while (tmp->next != nullptr)
		{
			tmp = tmp->next;

		}
		tmp->next = newL;
	}
}

void removeElem(List* head, int value)
{
	if (head == nullptr)
	{
		cout << "" << endl;
		return;
	}
	if (head->data == value)
	{
		List* tmp = head;
		head = head->next;
		delete tmp; return;
	}

	List* tmp = head;
	while (tmp->next != nullptr)
	{
		tmp = tmp->next;
	}
	if (tmp->next = nullptr)
	{
		cout << "" << endl; return;
	}
	List* delElem = tmp->next;
	tmp->next = tmp->next->next;
	delete delElem;
}

// Функция очистки списка
void clearlist(List*& head) {
	while (head != nullptr) {
		List* tmp = head;
		head = head->next;
		delete tmp;
	}
}

void zerolist(List*& head) {
	cout << "Список элеменов обнулен" << endl;
