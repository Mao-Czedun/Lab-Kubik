void SortList(List* head)
{
	List* curr = head;
	int xam = 0;
	//while (curr != nullptr)
	if (curr->next != nullptr)
	{
		if (curr->data < curr->next->data)
		{
			xam = curr->data;
			curr->data = curr->next->data;
			curr->next->data = xam;
			SortList(curr->next);
		}
		curr = curr->next;
		SortList(curr->next);
	}
	cout << "Список отсортирован " << endl;
}

bool Uplist(List* head) {
	bool f = true;
	while (head->next != nullptr) {
		if (head ->data > head->next ->data) {
			f = false;
			head = head->next;
		}
	}
	return f;
}

int SumList(List* head)
{
	int sm = 0;
	List* tmp = head;
	while (tmp != nullptr)
	{
		sm += tmp->data; 
		tmp = tmp->next;
	}
	return sm;
}

int ColList(List* head)
{
	int ch = 0;
	List* tmp = head;
	while (tmp != nullptr) 
	{
		ch += 1;
		tmp = tmp->next;
	}
	return ch;
}

