struct tree {
	int info;
	tree* L;
	tree* R;
};

void add(tree* t, int x)
{
	tree* t;
	if (x < t->info)
		if (t->L == NULL)
		{
			t = new(tree); t->info = x;
			t->L = NULL; t->R = NULL; t->L = t;
		}
		else add(t->L, x);
	else
		if (t->R == NULL) {
			t = new(tree); t->info = x;
			t->L = NULL; t->R = NULL; t->R = t;
		}
		else add(t->R, x);
}

void print(tree* t)
{
	if (t != NULL)
	{
		cout << "\nElem:" << t->info;
		cout << "---" << endl;
		print(t->L);
		print(t->R);
	}
}


