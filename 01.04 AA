struct Tree {
	int info; //информационное поле
	Tree* left; //указатель на левый потомок
	Tree* right; //указатель на правый потомок
};
void Add(Tree* root, int data)
{
	if (data < root->info)
		if (root->left == NULL) {
			Tree* q;
			q = new(Tree);
			q->info = data;
			q->left = NULL;
			q->right = NULL;
			root->left = q;
		}
		else Add(root->left, data);
	else
		if (root->right == NULL) {
			Tree* q;
			q = new(Tree);
			q->info = data;
			q->left = NULL;
			q->right = NULL;
			root->right = q;
		}
		else Add(root->right, data);
}
void Destroy(Tree* root) {
	if (root == NULL)
		return;
	Destroy(root->left);
	Destroy(root->right);
	delete root;
}
void print(Tree* root) {
	if (root == NULL)return;
	cout << root->info << " ";
	print(root->left);
	print(root->right);
}
void TreeToFile(Tree* t, ofstream &f) {
	if (t != NULL) {
		f << t->info << endl;
		TreeToFile(t->left, f);
		TreeToFile(t->right, f);
	}
}
Tree* FileToTree(ifstream& f) {
	Tree* t = new Tree;
	f >> t->info; // корень дерева
	t->left = NULL;
	t->right = NULL; //готовое дерево из f узла
	while (f >> t->info) {
		Add(t, t->info);
	}
	return t;
}
