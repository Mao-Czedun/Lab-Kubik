struct tree {
	int info;
	tree* L;
	tree* R;
};

void Add(tree* root, int data){
	if (data < root->info)
		if (root->L == NULL) {
			tree* q;
			q = new(tree);
			q->info = data;
			q->L = NULL;
			q->R = NULL;
			root->L = q;
		}
		else Add(root->L, data);
	else
		if (root->R == NULL) {
			tree* q;
			q = new(tree);
			q->info = data;
			q->L = NULL;
			q->R = NULL;
			root->R = q;
		}
		else Add(root->R, data);
}

void TreeToBin(tree* root, ofstream &f ) {
	if (root != nullptr) 
	{
		f << root->info << endl;
		TreeToBin(root->L,f);
		TreeToBin(root->R,f);
	}
}


int main() {
	setlocale(LC_ALL, "Rus");
	tree* root = NULL;
	int x;
	cout << "Введите элементы)" << endl;
		cin >> x;
	if (x != 0) {
		root = new tree;
		root->info = x;
		root->L = NULL;
		root->R = NULL;
	}
	for (cin >> x; x != 0; cin >> x)
		Add(root, x);
	cout << "Укажи имя ";
	string s;
	cin >> s;
	ofstream f;
	f.open(s, ios::binary);
	f.close();
}
