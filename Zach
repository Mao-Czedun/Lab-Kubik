// Задача №2-3 Найти сумму ряда ∑_(i=1)^n▒7^i/(i+5)!

int main() {
    setlocale(LC_ALL, "Rus");
    int n, fac = 1;
    cout << "Введите n: ";
    cin >> n;
    float sum = 0.0, p = 1.0;
    for (int j = 1; j <= 5; j++) {
        fac *= j;
    }
    for (int i = 1; i <= n; i++) {
        fac *= (i + 5);
        p *= 7;
        sum += p / fac;
    }
    cout << "Сумма ряда S = " << sum << endl;
    return 0;
}

//  Задача №3-3.  Дан массив целых чисел. Найти элемент, сумма цифр которого максимальна.

int main() {
	setlocale(LC_ALL, "Rus");
	int m[9] = {11, 232, 373, 474, 5222, 612, 75, 80, 9},n=9,mas=0;
	for (int i = 0; i < 9; i++) {
		int ch,msch=0;
		ch = m[i];
		while (ch != 0){
			msch += ch % 10;
			ch /= 10;
		}
		if (mas < msch) {
			mas = msch;
		}
	}
	cout << mas;
	return(0);
}

// Задача №4-3.  Дана целочисленная неквадратная матрица. Определить каких столбцов в матрице больше: содержащих только положительные элементы, или содержащих только отрицательные элементы?

int main() {
	setlocale(LC_ALL, "Rus");
	int pl = 0, otr = 0;
	int m[4][2] = { { 1,-2 }, { -14,-15 }, { -3,-5 }, {6,3 } };
	int n = 4, nn = 1;
	for (int i = 0; i < n; i++) {
		for (int j = 0; j < nn; j++) {
			if (((m[i][j]) < 0) && (m[i][j+1]) < 0) {
				otr += 1;
			}
			if (((m[i][j]) > 0) && (m[i][j + 1]) > 0) {
				pl += 1;
			}
		}
	}
	cout << otr << "  " << pl << endl;
	if (otr < pl) {
		cout << "столбцов в матрице содержащих только положительные элементы больше ";
	}
	else {
		cout << "столбцов содержащих только отрицательные элементы в матрице больше ";
	}
}

// Задача №5-3. 3.	Дана последовательность из n целых чисел. Найти произведение простых элементов, до и после которых расположены непростые.

int npr(int n) {
	int g = n,d=0;
	for (int i = 2; i < g; i++) {
		if (g % i == 0) {
			d += 1;
		}
	}
	if (d > 0){
		return(1);
	}
	else {
		return(0);
	}
}

int pr(int n) {
	int g = n, d = 0;
	for (int i = 2; i < g; i++) {
		if (g % i == 0) {
			d += 1;
		}
	}
	if (d == 0) {
		return(1);
	}
	else {
		return(0);
	}
}


int main() {
	setlocale(LC_ALL, "Rus");
	int n,sim=1;
	cout << " Введи длину последовательности " << endl;
	cin >> n;
	cout << "Введи элементы последовательности " << endl;
	int m[999];
	for (int i = 0; i < n; i++) {
		cin >> m[i];
	}
	for (int i = 1; i < n - 1; i++) {
		if (pr(m[i]) == 1 && npr(m[i - 1]) == 1 && npr(m[i + 1]) == 1) {
		sim = sim * m[i];
		}
	}
	cout << sim;
}
