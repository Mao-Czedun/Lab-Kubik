#include <iostream>
#include <clocale>

using namespace std;

struct STEC {
    int data;
    STEC* next;
};

STEC* create() {
    return NULL;
}

bool isempty(STEC* top) {
    return (top == NULL);
}

void Push(STEC*& top, int x) {
    STEC* p = new STEC;
    p->data = x;
    p->next = top;
    top = p;
}

void Print(STEC*& top) {
    if (!isempty(top)) {
        cout << top->data << ", ";
    }
}

int Chis(STEC*& top) {
    if (!isempty(top)) {
        return(top->data);
    }
}

int main() {
    setlocale(LC_ALL, "Rus");
    srand(time(0));
    int n = 4, sim=0;
    STEC* s = create();
    cout << "Стекъ: " << endl;
    for (int i = 0; i < n; i++) {
        int x = rand() % 10;
        Push(s, x);
        Print(s);
        sim += Chis(s);
    }
    cout << endl << "Cумма элементов стека: " << endl << sim;
    return(0);
}
